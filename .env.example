# Bookworm is $0 by default (mock student). No keys required.
# BOOKWORM_STUDENT_BACKEND=mock   # mock | ollama | echo

# Free local upgrade via Ollama (https://ollama.com) — still no API keys:
# BOOKWORM_OLLAMA_HOST=http://127.0.0.1:11434
# BOOKWORM_OLLAMA_MODEL=llama3.2

# Paid cloud backends are intentionally not required and not wired by default.
